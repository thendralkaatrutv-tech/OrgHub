<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#FF111118">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add Reminder"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/etSubject"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Reminder subject..."
        android:textColor="#FFFFFF"
        android:textColorHint="#888899"
        android:padding="10dp"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnPickTime"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:text="Pick Date and Time"
        android:textColor="#FFFFFF"
        android:backgroundTint="#FF2196F3"
        android:layout_marginBottom="6dp" />

    <TextView
        android:id="@+id/tvSelectedTime"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No time selected"
        android:textColor="#888899"
        android:textSize="13sp"
        android:gravity="center"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Voice:"
        android:textColor="#FFFFFF"
        android:textSize="14sp" />

    <RadioGroup
        android:id="@+id/rgGender"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <RadioButton
            android:id="@+id/rbFemale"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="Female"
            android:textColor="#FFFFFF"
            android:checked="true" />

        <RadioButton
            android:id="@+id/rbMale"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="Male"
            android:textColor="#FFFFFF" />

    </RadioGroup>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Speed:"
        android:textColor="#FFFFFF"
        android:textSize="14sp" />

    <RadioGroup
        android:id="@+id/rgSpeed"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <RadioButton
            android:id="@+id/rbSlow"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="Slow"
            android:textColor="#FFFFFF" />

        <RadioButton
            android:id="@+id/rbNormal"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="Normal"
            android:textColor="#FFFFFF"
            android:checked="true" />

        <RadioButton
            android:id="@+id/rbFast"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="Fast"
            android:textColor="#FFFFFF" />

    </RadioGroup>

</LinearLayout>
